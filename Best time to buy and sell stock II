

int maxProfit(int* prices, int pricesSize) {
    // Handle edge case: if there are no prices or only one day, no profit can be made
    if (pricesSize <= 1) {
        return 0;
    }

    int total_profit = 0;

    // Iterate through the array starting from the second day
    for (int i = 1; i < pricesSize; i++) {
        // If the price today is higher than the price yesterday
        if (prices[i] > prices[i - 1]) {
            // Add the difference to our total profit
            total_profit += (prices[i] - prices[i - 1]);
        }
    }

    return total_profit;
}
