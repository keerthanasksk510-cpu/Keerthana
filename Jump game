

bool canJump(int* nums, int numsSize) {
    int maxReach = 0;

    for (int i = 0; i < numsSize; i++) {
        // If the current index is beyond our maximum reach, we are stuck
        if (i > maxReach) {
            return false;
        }

        // Update maxReach to the furthest index we can jump to from here
        if (i + nums[i] > maxReach) {
            maxReach = i + nums[i];
        }

        // Optimization: If we can already reach the last index, return true
        if (maxReach >= numsSize - 1) {
            return true;
        }
    }

    return maxReach >= numsSize - 1;
}
