

int canCompleteCircuit(int* gas, int gasSize, int* cost, int costSize) {
    int total_surplus = 0;   // To check if a solution exists at all
    int current_surplus = 0; // To check if the current starting point is valid
    int start_index = 0;

    for (int i = 0; i < gasSize; i++) {
        int diff = gas[i] - cost[i];
        total_surplus += diff;
        current_surplus += diff;

        // If current_surplus drops below 0, we cannot reach the next station
        if (current_surplus < 0) {
            // Pick the next station as the new potential starting point
            start_index = i + 1;
            // Reset current tank for the new start
            current_surplus = 0;
        }
    }

    // If total gas is less than total cost, return -1
    if (total_surplus < 0) {
        return -1;
    }

    return start_index;
}
