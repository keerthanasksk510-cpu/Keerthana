int removeDuplicates(int* nums, int numsSize) {
    // If the array is empty, return 0
    if (numsSize == 0) {
        return 0;
    }

    // 'k' is the count of unique elements and also the index 
    // where the next unique element should be placed.
    // We start at 1 because the first element is always unique.
    int k = 1;

    for (int i = 1; i < numsSize; i++) {
        // Compare current element with the last unique element found
        if (nums[i] != nums[k - 1]) {
            // If they are different, it's a new unique element
            nums[k] = nums[i];
            k++;
        }
    }

    // k represents the total number of unique elements
    return k;
}
