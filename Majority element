int majorityElement(int* nums, int numsSize) {
    int candidate = 0;
    int count = 0;

    for (int i = 0; i < numsSize; i++) {
        // If count is 0, we pick a new candidate
        if (count == 0) {
            candidate = nums[i];
        }

        // If the current number is the candidate, increment count
        // Otherwise, decrement count
        if (nums[i] == candidate) {
            count++;
        } else {
            count--;
        }
    }

    // Since the problem guarantees a majority element exists, 
    // the current candidate is the answer.
    return candidate;
}
