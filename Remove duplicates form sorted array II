int removeDuplicates(int* nums, int numsSize) {
    // If the array has 2 or fewer elements, it already meets the condition
    if (numsSize <= 2) {
        return numsSize;
    }

    // 'k' is the write pointer. The first two elements are always allowed.
    int k = 2;

    for (int i = 2; i < numsSize; i++) {
        /* 
           If the current element nums[i] is NOT equal to the element 
           at index k-2, it means we haven't encountered more than 
           two of this value yet.
        */
        if (nums[i] != nums[k - 2]) {
            nums[k] = nums[i];
            k++;
        }
    }

    // k represents the length of the modified array
    return k;
}
