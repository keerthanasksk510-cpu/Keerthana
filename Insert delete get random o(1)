import random

class RandomizedSet:

    def __init__(self):
        # List to store elements for O(1) getRandom
        self.nums = []
        # Dictionary to store value -> index for O(1) lookup
        self.pos = {}

    def insert(self, val):
        if val in self.pos:
            return False
        
        # Add to the map: current length is the index where the new item goes
        self.pos[val] = len(self.nums)
        self.nums.append(val)
        return True

    def remove(self, val):
        if val not in self.pos:
            return False
        
        # Get the index of the item to remove and the value of the last item
        idx_to_remove = self.pos[val]
        last_element = self.nums[-1]
        
        # 1. Move the last element to the spot of the element we're removing
        self.nums[idx_to_remove] = last_element
        # 2. Update the map to reflect that the 'last_element' has a new index
        self.pos[last_element] = idx_to_remove
        
        # 3. Remove the redundant last element from the list
        self.nums.pop()
        # 4. Remove the deleted value from the map
        del self.pos[val]
        
        return True

    def getRandom(self):
        # random.choice uses the list's O(1) access to pick a random item
        return random.choice(self.nums)
