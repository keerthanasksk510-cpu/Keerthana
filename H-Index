

int hIndex(int* citations, int citationsSize) {
    int n = citationsSize;
    // Create buckets to store counts of citations. 
    // size is n + 1 to account for 0 to n citations.
    int* buckets = (int*)calloc(n + 1, sizeof(int));

    // Fill the buckets
    for (int i = 0; i < n; i++) {
        if (citations[i] >= n) {
            buckets[n]++;
        } else {
            buckets[citations[i]]++;
        }
    }

    int totalPapers = 0;
    // Iterate from the back (highest possible h-index) to the front
    for (int h = n; h >= 0; h--) {
        totalPapers += buckets[h];
        // If the number of papers with at least h citations is >= h
        if (totalPapers >= h) {
            free(buckets); // Clean up allocated memory
            return h;
        }
    }

    free(buckets);
    return 0;
}
