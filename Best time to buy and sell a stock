int maxProfit(int* prices, int pricesSize) {
    // If there are fewer than 2 days, no profit can be made
    if (pricesSize <= 1) {
        return 0;
    }

    // Initialize minPrice to the first day's price
    int minPrice = prices[0];
    int maxProfit = 0;

    for (int i = 1; i < pricesSize; i++) {
        // If we found a new lower price, update minPrice
        if (prices[i] < minPrice) {
            minPrice = prices[i];
        } 
        // Otherwise, calculate the profit if we sold today 
        // and update maxProfit if it's the best so far
        else {
            int currentProfit = prices[i] - minPrice;
            if (currentProfit > maxProfit) {
                maxProfit = currentProfit;
            }
        }
    }

    return maxProfit;
}
