
int* productExceptSelf(int* nums, int numsSize, int* returnSize) {
    // 1. Allocate memory for the result array
    int* answer = (int*)malloc(numsSize * sizeof(int));
    *returnSize = numsSize;

    answer[0] = 1; // Nothing to the left of the first element
    for (int i = 1; i < numsSize; i++) {
        answer[i] = answer[i - 1] * nums[i - 1];
    }

    int rightProduct = 1; 
    for (int i = numsSize - 1; i >= 0; i--) {
        // Multiply the current prefix product with the suffix product
        answer[i] = answer[i] * rightProduct;
        
        // Update the suffix product for the next element to the left
        rightProduct *= nums[i];
    }

    return answer;
}
