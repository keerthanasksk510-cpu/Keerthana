

// Helper function to return the value of a Roman symbol
int getRomanValue(char c) {
    switch (c) {
        case 'I': return 1;
        case 'V': return 5;
        case 'X': return 10;
        case 'L': return 50;
        case 'C': return 100;
        case 'D': return 500;
        case 'M': return 1000;
        default: return 0;
    }
}

int romanToInt(char* s) {
    int total = 0;
    int length = strlen(s);

    for (int i = 0; i < length; i++) {
        int current = getRomanValue(s[i]);
        
        // Peek at the next value if it exists
        int next = (i + 1 < length) ? getRomanValue(s[i + 1]) : 0;

        // Subtraction Rule: If current is smaller than next, subtract it
        if (current < next) {
            total -= current;
        } else {
            // Addition Rule: Otherwise, add it
            total += current;
        }
    }

    return total;
}
