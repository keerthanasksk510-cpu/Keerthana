

int jump(int* nums, int numsSize) {
    // If the array has only one element, we are already at the destination
    if (numsSize <= 1) {
        return 0;
    }

    int jumps = 0;
    int current_end = 0;
    int farthest = 0;

    // We iterate up to numsSize - 1 because we don't need to jump 
    // once we reach or pass the last index.
    for (int i = 0; i < numsSize - 1; i++) {
        // Update the farthest index we can reach from the current position
        if (i + nums[i] > farthest) {
            farthest = i + nums[i];
        }

        // If we have reached the end of the range for the current jump
        if (i == current_end) {
            jumps++;
            current_end = farthest;

            // Optimization: If we can already reach the last index, break
            if (current_end >= numsSize - 1) {
                break;
            }
        }
    }

    return jumps;
}
